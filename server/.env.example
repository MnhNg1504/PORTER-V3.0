# POTTER 3.0 — Backend. Copy thành .env và điền giá trị thật. KHÔNG commit .env.

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL/PostGIS (khớp docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USER=potter
DB_PASSWORD=potter_dev_only
DB_NAME=potter

# JWT — sinh chuỗi ngẫu nhiên dài ≥32 ký tự cho production
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# Seed dữ liệu cung (GPX thật)
GPX_DIR=../16 Đỉnh Tây Bắc

# (GĐ3) OAuth
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
