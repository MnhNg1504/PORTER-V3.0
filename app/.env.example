# POTTER 3.0 — App mobile (Expo). Copy thành .env và điền giá trị thật.
# KHÔNG commit .env. Biến EXPO_PUBLIC_* sẽ nhúng vào bundle client.

# URL backend API (server/ — NestJS)
EXPO_PUBLIC_API_URL=http://localhost:3000

# WebSocket chat
EXPO_PUBLIC_WS_URL=ws://localhost:3000

# Style bản đồ vector (mặc định OpenFreeMap — miễn phí, không cần key)
EXPO_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/positron

# (Tuỳ chọn) MapTiler/Stadia key nếu dùng tile trả phí
EXPO_PUBLIC_MAPTILER_KEY=

# (GĐ3) Push notifications — Expo project id
EXPO_PUBLIC_EAS_PROJECT_ID=
